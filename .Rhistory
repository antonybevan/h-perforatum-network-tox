"3.7× Mean", "Baseline",          # Bootstrap
"Pass", "Pass"                    # Chem Sim
),
# Text Color logic
TextColor = c(
"black", "white",  # Proximity - Quercetin is stronger
"white", "black",  # RWI - Hyperforin is stronger
"white", "black",  # EWI - Hyperforin is stronger
"white", "black",
"black", "black"
)
)
# Order factors reverse for plotting top-to-bottom
heatmap_data$Tier <- factor(heatmap_data$Tier, levels = rev(unique(heatmap_data$Tier)))
heatmap_data$Compound <- factor(heatmap_data$Compound, levels = c("Hyperforin", "Quercetin"))
# --- Create Heatmap ---
fig_heatmap <- ggplot(heatmap_data, aes(x = Compound, y = Tier, fill = Strength)) +
# Tiles
geom_tile(color = "white", linewidth = 1.5) +
# Labels
geom_text(
aes(label = Label, color = TextColor),
fontface = "bold", size = 3.8, lineheight = 0.9
) +
# Color scale - One color (Blue) intensity represents "Strength of Signal"
scale_fill_gradient(
low = "#E6F0FF",      # Very light blue
high = "#00468B",     # Deep blue
name = "Signal\nStrength",
limits = c(0, 11)
) +
scale_color_identity() + # Use mapped text colors
# Labels
labs(
title = "Tiered Inference: The Proximity-Influence Paradox",
subtitle = "Quercetin wins on Proximity (Tier 1), but Hyperforin dominates Influence (Tiers 2-4)",
x = NULL,
y = NULL,
caption = "Signal Strength = |Z-score| for Proximity/Influence | STRING ≥900"
) +
# Theme
theme_lancet() +
theme(
axis.text.x = element_text(face = "bold", size = 12),
axis.text.y = element_text(face = "bold", size = 11),
panel.grid = element_blank(),
legend.position = "right"
) +
coord_fixed(ratio = 0.6)
# --- Display ---
print(fig_heatmap)
# --- Save ---
save_figure(fig_heatmap, "fig4_tiered_heatmap_corrected", width = 180, height = 140)
message("\n✓ Corrected Figure 4 created and saved to figures/main/")
# ============================================================================
# 06_fig_paradox.R - Figure 5: Proximity-Influence Paradox (Lancet Style)
# Scatter plot of Shortest Path (d_c) vs Random Walk Influence (RWI)
# ============================================================================
source(here::here("R", "00_setup.R"))
source(here::here("R", "01_load_data.R"))
# --- Prepare Data ---
paradox_data <- tibble(
Compound = c("Hyperforin", "Quercetin"),
# Proximity Z-score (Negative = Closer)
Proximity_Z = c(
sp_900 %>% filter(compound == "Hyperforin") %>% pull(z_score),
sp_900 %>% filter(compound == "Quercetin") %>% pull(z_score)
),
# Influence Z-score (Positive = Stronger)
Influence_Z = c(
rwr_900 %>% filter(compound == "Hyperforin") %>% pull(z_score),
rwr_900 %>% filter(compound == "Quercetin") %>% pull(z_score)
),
# Target count for size
Targets = c(10, 62)
)
# --- Create Scatter Plot ---
fig_paradox <- ggplot(paradox_data, aes(x = Proximity_Z, y = Influence_Z)) +
# Quadrant lines
geom_hline(yintercept = 0, linetype = "dashed", color = "#999999") +
geom_vline(xintercept = 0, linetype = "dashed", color = "#999999") +
# Points
geom_point(aes(size = Targets, fill = Compound), shape = 21, color = "black", stroke = 1) +
# Annotation Arrows
annotate("segment", x = -6, xend = -2, y = -1, yend = -1,
arrow = arrow(length = unit(0.3, "cm")), color = "#666666") +
annotate("text", x = -4, y = -2, label = "Closer to DILI →", color = "#666666", size = 3.5) +
annotate("segment", x = 1, xend = 1, y = 1, yend = 11,
arrow = arrow(length = unit(0.3, "cm")), color = "#666666") +
annotate("text", x = 2, y = 6, label = "Stronger Influence ↑", color = "#666666", size = 3.5, angle = 90) +
# Labels for Points
geom_label_repel(
aes(label = paste0(Compound, "\n(Z_inf=", round(Influence_Z, 1), ", Z_prox=", round(Proximity_Z, 1), ")")),
box.padding = 1.0, point.padding = 0.5,
size = 4, fontface = "bold"
) +
# Scales
scale_size_continuous(range = c(5, 12), name = "Target Count") +
scale_fill_manual(values = c("Hyperforin" = "#00468B", "Quercetin" = "#ED0000")) +
# Axes limits to show quadrants clearly
scale_x_continuous(limits = c(-7, 3), breaks = seq(-6, 2, 2)) +
scale_y_continuous(limits = c(-2, 12), breaks = seq(0, 12, 4)) +
# Labels
labs(
title = "The Proximity-Influence Paradox",
subtitle = "Quercetin is topologically closer (more negative X) but exerts weaker influence (lower Y)",
x = "Proximity Z-score (Shortest Path)",
y = "Influence Z-score (Random Walk)",
caption = "Negative X = Closer than random | Positive Y = Stronger influence than random"
) +
# Theme
theme_lancet() +
theme(
legend.position = "bottom",
panel.border = element_rect(color = "black", fill = NA, user_settings_size = 0.5)
)
# --- Display ---
print(fig_paradox)
# --- Save ---
save_figure(fig_paradox, "fig5_paradox_scatter", width = 160, height = 160)
message("\n✓ Figure 5 (Paradox Scatter) created and saved to figures/main/")
# ============================================================================
# 00_setup.R - Lancet-Quality Visualization Setup
# H. perforatum Network Toxicology Analysis
# ============================================================================
# --- Package Installation ---
required_packages <- c(
# Core visualization
"ggplot2", "ggpubr", "patchwork", "scales",
# Network visualization
"igraph", "ggraph", "tidygraph",
# Publication themes
"ggsci", "ggthemes", "extrafont",
# Statistical annotations
"ggrepel", "ggsignif", "ggdist",
# Data wrangling
"tidyverse", "readr", "here",
# Tables
"gt", "kableExtra"
)
# Install missing packages
install_if_missing <- function(pkg) {
if (!require(pkg, character.only = TRUE)) {
install.packages(pkg, dependencies = TRUE)
library(pkg, character.only = TRUE)
}
}
invisible(lapply(required_packages, install_if_missing))
# --- Lancet Theme ---
theme_lancet <- function(base_size = 12) {
theme_minimal(base_size = base_size) +  # Use default font
theme(
# Clean background
panel.background = element_rect(fill = "white", color = NA),
plot.background = element_rect(fill = "white", color = NA),
panel.grid.major = element_line(color = "#EBEBEB", linewidth = 0.3),
panel.grid.minor = element_blank(),
# Professional axes
axis.line = element_line(color = "#333333", linewidth = 0.5),
axis.ticks = element_line(color = "#333333", linewidth = 0.3),
axis.text = element_text(color = "#333333", size = 10),
axis.title = element_text(color = "#000000", size = 11, face = "bold"),
# Clean legend
legend.background = element_rect(fill = "white", color = NA),
legend.key = element_rect(fill = "white", color = NA),
legend.title = element_text(face = "bold", size = 10),
legend.position = "bottom",
# Title styling
plot.title = element_text(face = "bold", size = 14, hjust = 0),
plot.subtitle = element_text(size = 11, color = "#666666"),
plot.caption = element_text(size = 9, color = "#999999", hjust = 1),
# Margins
plot.margin = margin(15, 15, 15, 15)
)
}
# --- Lancet Color Palette ---
lancet_colors <- c(
"Hyperforin" = "#00468B",   # Deep blue
"Quercetin" = "#ED0000",    # Lancet red
"DILI" = "#42B540",         # Green
"Null" = "#ADB6B6",         # Gray
"Significant" = "#0099B4",  # Teal
"NS" = "#925E9F"            # Purple
)
# Scale functions
scale_fill_lancet <- function(...) {
scale_fill_manual(values = lancet_colors, ...)
}
scale_color_lancet <- function(...) {
scale_color_manual(values = lancet_colors, ...)
}
# --- Export Settings ---
fig_width <- 180  # mm (journal column width)
fig_height <- 120 # mm
fig_dpi <- 300    # print quality
save_figure <- function(plot, filename, width = fig_width, height = fig_height) {
ggsave(
filename = here::here("figures", "main", paste0(filename, ".pdf")),
plot = plot,
width = width, height = height, units = "mm", dpi = fig_dpi
)
ggsave(
filename = here::here("figures", "main", paste0(filename, ".png")),
plot = plot,
width = width, height = height, units = "mm", dpi = 600
)
message(paste("Saved:", filename))
}
# --- Project Paths ---
data_dir <- here::here("results", "tables")
fig_dir <- here::here("figures", "main")
message("✓ Setup complete. Run 01_load_data.R next.")
# ============================================================================
# 02_fig_violin_pub.R - Figure 1 (Publication Quality)
# ============================================================================
source("R/00_setup_pub.R")
source("R/01_load_data.R")
# --- Prepare Data (Same logic, stricter styling) ---
set.seed(42)
n_sim <- 1500  # More points for smoother violin
violin_data <- bind_rows(
tibble(Compound="Hyperforin", Metric="RWI", Value=rnorm(n_sim,
mean=rwr_900 %>% filter(compound=="Hyperforin") %>% pull(null_mean),
sd=rwr_900 %>% filter(compound=="Hyperforin") %>% pull(null_std))),
tibble(Compound="Quercetin", Metric="RWI", Value=rnorm(n_sim,
mean=rwr_900 %>% filter(compound=="Quercetin") %>% pull(null_mean),
sd=rwr_900 %>% filter(compound=="Quercetin") %>% pull(null_std))),
tibble(Compound="Hyperforin", Metric="EWI", Value=rnorm(n_sim,
mean=ewr_900 %>% filter(compound=="Hyperforin") %>% pull(null_mean),
sd=ewr_900 %>% filter(compound=="Hyperforin") %>% pull(null_std))),
tibble(Compound="Quercetin", Metric="EWI", Value=rnorm(n_sim,
mean=ewr_900 %>% filter(compound=="Quercetin") %>% pull(null_mean),
sd=ewr_900 %>% filter(compound=="Quercetin") %>% pull(null_std)))
) %>% mutate(Metric = ifelse(Metric=="RWI", "Random Walk Influence (RWI)", "Expression Weighted (EWI)"))
observed_data <- tibble(
Compound = rep(c("Hyperforin", "Quercetin"), 2),
Metric = c("Random Walk Influence (RWI)", "Random Walk Influence (RWI)",
"Expression Weighted (EWI)", "Expression Weighted (EWI)"),
Value = c(
rwr_900 %>% filter(compound=="Hyperforin") %>% pull(observed_influence),
rwr_900 %>% filter(compound=="Quercetin") %>% pull(observed_influence),
ewr_900 %>% filter(compound=="Hyperforin") %>% pull(observed_influence),
ewr_900 %>% filter(compound=="Quercetin") %>% pull(observed_influence)
),
Z_score = c(
rwr_900 %>% filter(compound=="Hyperforin") %>% pull(z_score),
rwr_900 %>% filter(compound=="Quercetin") %>% pull(z_score),
ewr_900 %>% filter(compound=="Hyperforin") %>% pull(z_score),
ewr_900 %>% filter(compound=="Quercetin") %>% pull(z_score)
)
)
# --- Plot Construction ---
p <- ggplot() +
# 1. Null Distribution (Grey Violin)
geom_violin(
data = violin_data,
aes(x = Compound, y = Value),
fill = "#F0F0F0", color = NA, width = 0.6
) +
# 2. Boxplot (Minimal)
geom_boxplot(
data = violin_data,
aes(x = Compound, y = Value),
width = 0.1, fill = "white", color = "#404040", outlier.shape = NA, linewidth = 0.4
) +
# 3. Observed Values (Colored Points)
geom_point(
data = observed_data,
aes(x = Compound, y = Value, color = Compound),
size = 4, shape = 18  # Diamond shape
) +
# 4. Connecting Lines (to show shift vs Null)
geom_segment(
data = observed_data %>% mutate(Null_Mean = ifelse(Compound=="Hyperforin",
rwr_900 %>% filter(compound=="Hyperforin") %>% pull(null_mean), 0)),
aes(x = Compound, xend = Compound, y = 0, yend = Value), # Simplified for visual
linetype = "dotted", color = "#808080", linewidth = 0.4
) +
# 5. Professional Z-score Labels
geom_text(
data = observed_data,
aes(x = Compound, y = Value, label = paste0("Z = +", round(Z_score, 1))),
vjust = -1, size = 3.5, fontface = "bold", family = "Arial"
) +
# 6. Faceting
facet_wrap(~Metric, scales = "free_y") +
# 7. Scales & Theme
scale_color_manual(values = cols) +
labs(
title = "Significant Topological Influence on DILI Module",
subtitle = "Observed influence (diamonds) vs. degree-preserving null distributions (grey violins)",
y = "Network Influence Score",
x = NULL,
caption = "Data Source: STRING v12.0 (≥900 confidence) | n=1000 permutations | *P < 1e-16"
) +
theme_lancet_pub()
# --- Save ---
save_pub_plot(p, "fig1_violin_pub")
# ============================================================================
# 07_fig_composite.R - Figure 1 Composite (Lancet Style)
# Panel A: Violin Distribution | Panel B: Effect Size Forest Plot
# ============================================================================
source("R/00_setup_pub.R")
source("R/01_load_data.R")
# --- Prepare Data ---
set.seed(42)
n_sim <- 2000
# Panel A Data: Violin
violin_data <- bind_rows(
tibble(Compound="Hyperforin", Metric="RWI", Value=rnorm(n_sim,
mean=rwr_900 %>% filter(compound=="Hyperforin") %>% pull(null_mean),
sd=rwr_900 %>% filter(compound=="Hyperforin") %>% pull(null_std))),
tibble(Compound="Quercetin", Metric="RWI", Value=rnorm(n_sim,
mean=rwr_900 %>% filter(compound=="Quercetin") %>% pull(null_mean),
sd=rwr_900 %>% filter(compound=="Quercetin") %>% pull(null_std))),
tibble(Compound="Hyperforin", Metric="EWI", Value=rnorm(n_sim,
mean=ewr_900 %>% filter(compound=="Hyperforin") %>% pull(null_mean),
sd=ewr_900 %>% filter(compound=="Hyperforin") %>% pull(null_std))),
tibble(Compound="Quercetin", Metric="EWI", Value=rnorm(n_sim,
mean=ewr_900 %>% filter(compound=="Quercetin") %>% pull(null_mean),
sd=ewr_900 %>% filter(compound=="Quercetin") %>% pull(null_std)))
) %>% mutate(Metric = factor(Metric, levels=c("RWI", "EWI")))
# Panel B Data: Comparisons for Forest Plot
forest_data <- tibble(
Label = c("Hyperforin (RWI)", "Quercetin (RWI)", "Hyperforin (EWI)", "Quercetin (EWI)"),
Compound = c("Hyperforin", "Quercetin", "Hyperforin", "Quercetin"),
Metric = c("RWI", "RWI", "EWI", "EWI"),
Observed = c(
rwr_900 %>% filter(compound=="Hyperforin") %>% pull(observed_influence),
rwr_900 %>% filter(compound=="Quercetin") %>% pull(observed_influence),
ewr_900 %>% filter(compound=="Hyperforin") %>% pull(observed_influence),
ewr_900 %>% filter(compound=="Quercetin") %>% pull(observed_influence)
),
Null_Mean = c(
rwr_900 %>% filter(compound=="Hyperforin") %>% pull(null_mean),
rwr_900 %>% filter(compound=="Quercetin") %>% pull(null_mean),
ewr_900 %>% filter(compound=="Hyperforin") %>% pull(null_mean),
ewr_900 %>% filter(compound=="Quercetin") %>% pull(null_mean)
),
Null_SD = c(
rwr_900 %>% filter(compound=="Hyperforin") %>% pull(null_std),
rwr_900 %>% filter(compound=="Quercetin") %>% pull(null_std),
ewr_900 %>% filter(compound=="Hyperforin") %>% pull(null_std),
ewr_900 %>% filter(compound=="Quercetin") %>% pull(null_std)
),
Z_score = c(
rwr_900 %>% filter(compound=="Hyperforin") %>% pull(z_score),
rwr_900 %>% filter(compound=="Quercetin") %>% pull(z_score),
ewr_900 %>% filter(compound=="Hyperforin") %>% pull(z_score),
ewr_900 %>% filter(compound=="Quercetin") %>% pull(z_score)
)
) %>%
mutate(
CI_Lower = Null_Mean - 1.96 * Null_SD,
CI_Upper = Null_Mean + 1.96 * Null_SD,
Label = factor(Label, levels = rev(Label)) # Top to bottom
)
# --- Panel A: Violin Plot (Simplified) ---
pA <- ggplot(violin_data, aes(x = Compound, y = Value)) +
geom_violin(aes(fill = Compound), color = NA, alpha = 0.2, width = 0.7) +
geom_boxplot(width = 0.1, fill = "white", color = "#404040", outlier.shape = NA, linewidth = 0.3) +
facet_wrap(~Metric, scales = "free_y") +
scale_fill_manual(values = cols) +
labs(
tag = "A",
title = "Null Distributions vs. Biological Signal",
y = "Network Influence Score",
x = NULL
) +
theme_lancet_pub() +
theme(legend.position = "none")
# --- Panel B: Forest-style Effect Plot ---
pB <- ggplot(forest_data, aes(y = Label)) +
# 1. Null Range (Grey Strip)
geom_segment(aes(x = CI_Lower, xend = CI_Upper, y = Label, yend = Label),
color = "#C0C0C0", linewidth = 4, lineend = "round") +
# 2. Observed Value (Point)
geom_point(aes(x = Observed, color = Compound), size = 4, shape = 18) +
# 3. Z-score Annotation (Right side)
geom_text(aes(x = max(Observed)*1.15, label = paste0("Z = +", round(Z_score, 1))),
hjust = 0, size = 3.5, fontface = "bold", family = "Arial") +
scale_color_manual(values = cols) +
scale_x_continuous(expand = expansion(mult = c(0.05, 0.3))) + # Room for text
labs(
tag = "B",
title = "Effect Size & Significance",
subtitle = "Diamonds: Observed | Grey bars: 95% CI of Null",
x = "Influence Score",
y = NULL
) +
theme_lancet_pub() +
theme(
legend.position = "none",
axis.line.y = element_blank(),
axis.ticks.y = element_blank(),
panel.grid.major.y = element_blank() # Clean look
)
# --- Composite Figure ---
p_comp <- pA + pB +
plot_layout(widths = c(1, 1.2)) +
plot_annotation(
title = "Topological Influence of H. perforatum Constituents",
caption = "Data: STRING v12.0 (≥900) | n=1000 Permutations | Panel B Error Bars = 95% Confidence Interval of Null Hypothesis",
theme = theme(
plot.title = element_text(face = "bold", size = 16, family = "Arial"),
plot.caption = element_text(size = 9, color = "#606060", family = "Arial")
)
)
# --- Save ---
save_pub_plot(p_comp, "fig1_composite_forest")
# ============================================================================
# 08_fig_forest_rigorous.R - Figure 1 (Strict Statistical Rigor)
# Forest Plot of Observed Value vs Null Distribution Confidence Interval
# NO SIMULATED DATA. Precise Mean +/- 1.96 SD representation.
# ============================================================================
source("R/00_setup_pub.R")
source("R/01_load_data.R")
# --- Prepare Precise Summary Data ---
# We generally have: Observed, Null_Mean, Null_SD.
# We test against the Null Hypothesis (H0).
# Significance: Is Observed outside [Mean - 1.96*SD, Mean + 1.96*SD]?
plot_data <- tibble(
Compound = rep(c("Hyperforin", "Quercetin"), 2),
Metric = c("RWI", "RWI", "EWI", "EWI"),
Observed = c(
rwr_900 %>% filter(compound=="Hyperforin") %>% pull(observed_influence),
rwr_900 %>% filter(compound=="Quercetin") %>% pull(observed_influence),
ewr_900 %>% filter(compound=="Hyperforin") %>% pull(observed_influence),
ewr_900 %>% filter(compound=="Quercetin") %>% pull(observed_influence)
),
Null_Mean = c(
rwr_900 %>% filter(compound=="Hyperforin") %>% pull(null_mean),
rwr_900 %>% filter(compound=="Quercetin") %>% pull(null_mean),
ewr_900 %>% filter(compound=="Hyperforin") %>% pull(null_mean),
ewr_900 %>% filter(compound=="Quercetin") %>% pull(null_mean)
),
Null_SD = c(
rwr_900 %>% filter(compound=="Hyperforin") %>% pull(null_std),
rwr_900 %>% filter(compound=="Quercetin") %>% pull(null_std),
ewr_900 %>% filter(compound=="Hyperforin") %>% pull(null_std),
ewr_900 %>% filter(compound=="Quercetin") %>% pull(null_std)
),
Z_score = c(
rwr_900 %>% filter(compound=="Hyperforin") %>% pull(z_score),
rwr_900 %>% filter(compound=="Quercetin") %>% pull(z_score),
ewr_900 %>% filter(compound=="Hyperforin") %>% pull(z_score),
ewr_900 %>% filter(compound=="Quercetin") %>% pull(z_score)
)
) %>%
mutate(
# Null Distribution 95% Interval
Null_Lower = Null_Mean - 1.96 * Null_SD,
Null_Upper = Null_Mean + 1.96 * Null_SD,
# Comparison Label
Label = paste0(Compound, " (", Metric, ")"),
# Order for plotting (Hyperforin top)
Label = factor(Label, levels = rev(c(
"Hyperforin (RWI)", "Quercetin (RWI)",
"Hyperforin (EWI)", "Quercetin (EWI)"
)))
)
# --- Forest Plot Construction ---
# Use separate points for "Observed" and "Null Mean" to show the shift clearly.
# Null Interval is a transparent rectangle or error bar around Null Mean.
p <- ggplot(plot_data, aes(y = Label)) +
# 1. Null Hypothesis Region (The "Background Noise")
# representing the 95% CI of the Null Distribution
geom_errorbarh(
aes(xmin = Null_Lower, xmax = Null_Upper, y = Label),
height = 0.5, color = "#999999", linewidth = 0.8
) +
geom_point(
aes(x = Null_Mean),
shape = 124, size = 8, color = "#999999" # Vertical bar for mean
) +
# 2. Observed Value (The Signal)
geom_point(
aes(x = Observed, color = Compound),
size = 4, shape = 18 # Diamond
) +
# 3. Connector (Effect Size Visual)
geom_segment(
aes(x = Null_Upper, xend = Observed, y = Label, yend = Label, color = Compound),
linetype = "dotted", linewidth = 0.5,
data = plot_data %>% filter(Observed > Null_Upper) # Only draw if significant
) +
# 4. Data Table (Text Aligned on Right)
geom_text(
aes(x = max(Observed) * 1.15, label = paste0("Z = +", round(Z_score, 1))),
hjust = 0, size = 3.5, fontface = "bold", family = "Arial"
) +
# Styling
scale_color_manual(values = cols) +
scale_x_continuous(
expand = expansion(mult = c(0.05, 0.4)), # Room for text
name = "Network Influence Score"
) +
labs(
title = "Topological Influence vs. Null Expectation",
subtitle = "Diamonds: Observed Influence | Grey Bars: Null Expectation (Mean ± 1.96 SD)",
y = NULL,
caption = "Significant deviation from null (grey) indicates specific DILI targeting.\nData: STRING ≥900, Liver LCC. Z-scores derived from 1000 permutations."
) +
theme_lancet_pub() +
theme(
legend.position = "none",
axis.line.y = element_blank(),
axis.ticks.y = element_blank(),
panel.grid.major.y = element_line(color = "#F0F0F0")
)
# --- Save ---
save_pub_plot(p, "fig1_forest_rigorous")
