{
    "project": {
        "name": "h-perforatum-network-tox",
        "title": "Network Pharmacology of Hypericum perforatum Hepatotoxicity",
        "description": "Reproducible analysis demonstrating that network position—not target count—determines hepatotoxic influence",
        "version": "2.1.0",
        "created": "2025-12-24",
        "last_updated": "2025-12-30",
        "license": "MIT",
        "repository": "https://github.com/antonybevan/h-perforatum-network-tox"
    },
    "environment": {
        "python_version": "3.10+",
        "platforms": [
            "Windows",
            "Linux",
            "macOS"
        ],
        "random_seed": 42,
        "reproducibility": "Deterministic (sorted target lists, fixed seeds)"
    },
    "data_sources": {
        "string": {
            "name": "STRING Protein-Protein Interaction Database",
            "version": "12.0",
            "organism": "9606 (Homo sapiens)",
            "url": "https://string-db.org",
            "thresholds": [
                700,
                900
            ],
            "citation": "Szklarczyk D, et al. (2023). Nucleic Acids Res 51(D1):D483-D489"
        },
        "gtex": {
            "name": "Genotype-Tissue Expression Project",
            "version": "v8",
            "tissue": "Liver",
            "url": "https://gtexportal.org",
            "filter_criterion": "TPM >= 1",
            "citation": "GTEx Consortium (2020). Science 369(6509):1318-1330"
        },
        "dilirank": {
            "name": "DILIrank Drug-Induced Liver Injury Dataset",
            "url": "https://www.fda.gov/science-research/liver-toxicity-knowledge-base-ltkb",
            "compounds": 907,
            "citation": "Chen M, et al. (2016). Drug Discov Today 21(4):648-653"
        },
        "chembl": {
            "name": "ChEMBL Bioactivity Database",
            "version": "33",
            "url": "https://www.ebi.ac.uk/chembl/",
            "citation": "Zdrazil B, et al. (2024). Nucleic Acids Res 52(D1):D1180-D1192"
        }
    },
    "compounds": {
        "hyperforin": {
            "chembl_id": "CHEMBL464",
            "targets_raw": 14,
            "targets_lcc": 10,
            "mechanism": "PXR activation, CYP induction"
        },
        "quercetin": {
            "chembl_id": "CHEMBL50",
            "targets_raw": 87,
            "targets_lcc": 62,
            "mechanism": "Broad kinase/enzyme inhibition"
        }
    },
    "analysis": {
        "parameters": {
            "permutations": 1000,
            "restart_probability": 0.15,
            "convergence_threshold": 1e-6,
            "degree_matching_tolerance": 0.25,
            "fdr_method": "Benjamini-Hochberg"
        },
        "results": {
            "standard_rwr": {
                "file": "results/tables/standard_rwr_lcc_permutation_results.csv",
                "hyperforin_z": 10.27,
                "quercetin_z": 4.42,
                "ptni_ratio": 21.9
            },
            "expression_weighted": {
                "file": "results/tables/expression_weighted_rwr_permutation_results.csv",
                "hyperforin_z": 9.07,
                "quercetin_z": 5.56,
                "ptni_ratio": 16.9
            }
        },
        "core_finding": "Hyperforin exhibits 17-22x higher per-target network influence than Quercetin"
    },
    "pipeline": {
        "master_script": "scripts/run_pipeline.py",
        "total_steps": 11,
        "steps": [
            "Extract STRING networks",
            "Regenerate targets",
            "Regenerate DILI genes",
            "Create LCC-filtered data",
            "Validate data integrity",
            "Standard RWR permutation",
            "Expression-weighted RWR permutation",
            "Shortest path permutation",
            "Bootstrap sensitivity",
            "Chemical similarity control",
            "Generate documentation"
        ]
    },
    "tests": {
        "total": 68,
        "passed": 68,
        "coverage": "src/network_tox"
    },
    "citations": {
        "methods": [
            "Menche J, et al. (2015). Science 347(6224). DOI: 10.1126/science.1257601",
            "Guney E, et al. (2016). Nat Commun 7. DOI: 10.1038/ncomms10331",
            "Vanunu O, et al. (2010). PLOS Comput Biol 6. DOI: 10.1371/journal.pcbi.1000641"
        ]
    }
}